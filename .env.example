# BookCabinet environment variables
# Copy this file to .env and fill in the values.

# ─── Database ───────────────────────────────────────
# PostgreSQL connection string (required for drizzle ORM)
DATABASE_URL=postgresql://user:password@localhost:5432/bookcabinet

# ─── Server ─────────────────────────────────────────
# HTTP server port (default 5000)
PORT=5000

# Node environment: development | production
NODE_ENV=development

# ─── IRBIS library system ───────────────────────────
# IRBIS TCP host and port (default 172.29.67.70:6666)
# IRBIS_HOST=172.29.67.70
# IRBIS_PORT=6666

# ─── Telegram notifications ─────────────────────────
# TELEGRAM_BOT_TOKEN=<token from @BotFather>
# TELEGRAM_CHAT_ID=<chat or group id>

# ─── Hardware (Raspberry Pi only) ───────────────────
# Set to "1" to enable mock mode (no real GPIO)
# MOCK_MODE=1

# ─── RFID readers (serial ports) ────────────────────
# RRU9816_PORT=/dev/ttyUSB0
# IQRFID5102_PORT=/dev/ttyUSB2
